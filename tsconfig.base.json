{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@myorg/ui":      ["packages/ui/src/index.ts"],
      "@myorg/types":   ["packages/types/dist/index.d.ts"],
      "@myorg/mocks":   ["packages/mocks/src/index.ts"],
      "@myorg/mocks/*": ["packages/mocks/src/*.ts"]
    }
  }
}
